{
  "name": "luigi-landingpage",
  "version": "1.0.0",
  "description": "Luigi landingpage (https://luigi-project.io) — built with Eleventy",
  "private": true,
  "type": "module",
  "browserslist": [
    "last 2 versions",
    "ie >= 9",
    "ios >= 7"
  ],
  "scripts": {
    "prebuild": "node scripts/copy-blog.js",
    "build:css": "sass --no-source-map src/assets/scss/app.scss ../public/assets/css/app.css && postcss ../public/assets/css/app.css --replace --use autoprefixer",
    "build:js": "esbuild src/assets/js/app.js --bundle --minify --outfile=../public/assets/js/app.js",
    "build:11ty": "eleventy",
    "build": "npm run build:css && npm run build:js && npm run build:11ty",
    "watch:css": "sass --watch --no-source-map src/assets/scss/app.scss ../public/assets/css/app.css",
    "watch:js": "esbuild src/assets/js/app.js --bundle --watch --outfile=../public/assets/js/app.js",
    "watch:11ty": "eleventy --serve",
    "start": "npm run prebuild && npm run build:css && npm run build:js && npm-run-all --parallel watch:*"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.6",
    "@11ty/eleventy-plugin-handlebars": "1.0.0",
    "autoprefixer": "10.4.20",
    "esbuild": "0.28.1",
    "feed": "5.2.0",
    "gray-matter": "4.0.3",
    "marked": "18.0.5",
    "npm-run-all": "4.1.5",
    "postcss": "8.5.3",
    "postcss-cli": "11.0.1",
    "sass": "1.99.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
