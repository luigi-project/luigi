<!DOCTYPE html>
<html class="no-js" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{{#if title}}{{ title }} - {{/if}}Luigi - The Enterprise-Ready Micro Frontend Framework</title>
    <meta
      name="description"
      content="{{#if seoMetaDescription}}{{ seoMetaDescription }}{{else}}Luigi is a micro frontend framework that enables you to create a unified user experience across a large set of functionality{{/if}}"
    />

    <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/favicon.png" />
    <link rel="stylesheet" href="/assets/css/app.css" />
  </head>
  <body class="has-dark-bg">
    <script>
      // Apply the saved theme before first paint, otherwise users with the
      // light theme cookie set see a dark flash on every page load. Default
      // is dark; the cookie is set by app.js when the theme switcher is used.
      if (/(?:^|;\s*)dark-mode=false(?:;|$)/.test(document.cookie)) {
        document.body.classList.remove('has-dark-bg');
      }
    </script>
    {{> partials/header}}

    <div class="main-content">
      {{{ content }}}
    </div>

    {{> partials/footer}}

    <script src="/assets/js/app.js"></script>
  </body>
</html>
