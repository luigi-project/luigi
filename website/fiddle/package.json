{
  "name": "luigi-fiddle",
  "private": true,
  "scripts": {
    "start": "npm run dev",
    "build": "node patch.js && node build_patch_ui5.js && cross-env NODE_ENV=production webpack",
    "dev": "node patch.js && node build_patch_ui5.js && concurrently -k \"webpack --watch\" \"node ../../scripts/tools/simple-server/cli.mjs public --port 3000 --proxy /luigi-cdn=https://www.unpkg.com/@luigi-project\""
  },
  "dependencies": {
    "@luigi-project/client": "^2.31.0",
    "@luigi-project/container": "^1.7.7",
    "@luigi-project/core": "^2.31.0",
    "@luigi-project/plugin-auth-oauth2": "^2.31.0",
    "@luigi-project/plugin-auth-oidc": "^2.31.0",
    "@luigi-project/plugin-auth-oidc-pkce": "^0.42.0",
    "@ui5/webcomponents": "2.20.1",
    "@ui5/webcomponents-fiori": "2.20.1",
    "ace-builds": "1.43.6",
    "fs-extra": "11.3.4",
    "fundamental-styles": "0.23.0"
  },
  "devDependencies": {
    "concurrently": "10.0.3",
    "copy-webpack-plugin": "14.0.0",
    "cross-env": "7.0.3",
    "css-loader": "6.11.0",
    "mini-css-extract-plugin": "2.10.1",
    "replace-in-file": "7.2.0",
    "style-loader": "3.3.4",
    "svelte": "5.55.7",
    "svelte-loader": "3.2.4",
    "webpack": "5.105.4",
    "webpack-cli": "5.1.4"
  },
  "overrides": {
    "shell-quote": "1.9.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
